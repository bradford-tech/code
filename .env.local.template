# BradfordCode local build environment.
# Copy this file to .env.local (gitignored) and fill in values.
# Source it before running ./build.sh:  source .env.local

# --- Build configuration ---
export APP_NAME="BradfordCode"
export OS_NAME="osx"
export VSCODE_ARCH="arm64"
export VSCODE_QUALITY="stable"
export SHOULD_BUILD="yes"
export SHOULD_BUILD_REH="no"
export SHOULD_BUILD_REH_WEB="no"
export SHOULD_BUILD_CLI="no"
export SHOULD_BUILD_ZIP="no"
export SHOULD_BUILD_DMG="yes"
export CI_BUILD="no"
export DISABLE_UPDATE="no"

# --- Apple signing/notarization secrets ---
# Export your Developer ID Application cert as a .p12 from Keychain Access,
# then base64-encode it.
export CERTIFICATE_OSX_P12_DATA="$(base64 < /path/to/BradfordCode.p12)"
export CERTIFICATE_OSX_P12_PASSWORD="<the password you set when exporting the .p12>"

# Apple ID, app-specific password, and team ID for notarization.
# Generate the app-specific password at https://appleid.apple.com/account/manage
# Find your team ID at https://developer.apple.com/account#MembershipDetailsCard
export CERTIFICATE_OSX_ID="you@example.com"
export CERTIFICATE_OSX_APP_PASSWORD="abcd-efgh-ijkl-mnop"
export CERTIFICATE_OSX_TEAM_ID="ABCDEF1234"

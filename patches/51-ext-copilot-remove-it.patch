-
-interface IShellToolArgs {
-	command: string;
-	timeout?: number;
-}
-
-interface IWriteShellArgs {
-	command: string;
-}
-
-interface IReadShellArgs {
-	shell_id?: string;
-}
-
-interface IShutdownShellArgs {
-	shell_id?: string;

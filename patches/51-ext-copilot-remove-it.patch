-			case 'autopilot':
-				patch[SessionConfigKey.Mode] = 'interactive';
-				patch[SessionConfigKey.AutoApprove] = 'autopilot';
-				break;
-			case 'interactive':
-				patch[SessionConfigKey.Mode] = 'interactive';
-				break;
